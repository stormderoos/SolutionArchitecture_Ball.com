    {
      "name": "Demo — eventual consistency",
      "item": [
        {
          "name": "1. Plaats order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.orderId) pm.collectionVariables.set('orderId', data.orderId);",
                  "console.log('Nieuwe orderId =', pm.collectionVariables.get('orderId'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order\": { \"customerId\": 1 },\n  \"products\": [\n    { \"productId\": 1, \"amount\": 2 }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": ""
            }
          },
          "response": []
        },
        {
