    {
      "name": "Demo — eventual consistency",
      "description": "Voer in volgorde uit. Stap 1 plaatst een order en slaat de orderId op in een collection-variabele. De services reageren asynchroon op de events, dus wacht 1-2 seconden tussen de stappen. Zo zie je de orderstatus 'meegroeien' met de events (eventual consistency): Order created -> (parallel) Paid / Picking products / Shipment pending -> na inpakken -> Shipped.",
      "item": [
        {
          "name": "1. Plaats order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.orderId) pm.collectionVariables.set('orderId', data.orderId);",
                  "console.log('Nieuwe orderId =', pm.collectionVariables.get('orderId'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order\": { \"customerId\": 1 },\n  \"products\": [ { \"productId\": 1, \"amount\": 2 } ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:5000/order",
              "protocol": "http",
              "host": [ "localhost" ],
              "port": "5000",
              "path": [ "order" ]
            }
          },
          "response": []
        },
        {
          "name": "2. Bekijk betaling (aangemaakt door event)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5001/payment/{{orderId}}",
              "protocol": "http",
              "host": [ "localhost" ],
              "port": "5001",
              "path": [ "payment", "{{orderId}}" ]
            }
          },
          "response": []
        },
        {
          "name": "3. Bekijk order (status wordt 'Shipment pending')",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5010/order/{{orderId}}",
              "protocol": "http",
              "host": [ "localhost" ],
              "port": "5010",
              "path": [ "order", "{{orderId}}" ]
            }
          },
          "response": []
        },
        {
          "name": "4. Magazijn pakt order in",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{ \"orderId\": {{orderId}} }",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:5100/package",
              "protocol": "http",
              "host": [ "localhost" ],
              "port": "5100",
              "path": [ "package" ]
            }
          },
          "response": []
        },
        {
          "name": "5. Bekijk verzending (Shipped)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5004/shipment/order/{{orderId}}",
              "protocol": "http",
              "host": [ "localhost" ],
              "port": "5004",
              "path": [ "shipment", "order", "{{orderId}}" ]
            }
          },
          "response": []
        },
        {
          "name": "6. Bekijk order (status is nu 'Shipped')",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5010/order/{{orderId}}",
              "protocol": "http",
              "host": [ "localhost" ],
              "port": "5010",
              "path": [ "order", "{{orderId}}" ]
            }
          },
          "response": []
        }
      ]
